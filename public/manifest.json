{
  "manifest_version": 3,
  "name": "SOLWALL — Solana Wallet",
  "version": "1.0.0",
  "description": "Non-custodial Solana wallet. Multiple wallets and accounts, send, receive, swap, and connect to Solana apps. Keys never leave your device.",
  "minimum_chrome_version": "110",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SOLWALL",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://localhost/*", "http://127.0.0.1/*"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["inpage.js"],
      "matches": ["https://*/*", "http://localhost/*", "http://127.0.0.1/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https: http://localhost:* http://127.0.0.1:*"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://solana-rpc.publicnode.com/*",
    "https://api.mainnet-beta.solana.com/*",
    "https://api.devnet.solana.com/*",
    "https://api.testnet.solana.com/*",
    "https://lite-api.jup.ag/*",
    "https://api.coingecko.com/*",
    "https://open.er-api.com/*"
  ]
}
